---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { EditorLayout } from '@/components/editor/EditorLayout';

export function getStaticPaths() {
	return [
		{ params: { projectId: 'demo' } },
	];
}

---

<BaseLayout title="Editor — Stitch UI" description="Typst document editor with live preview">
	<style is:global>
		/* Ensure the editor fills the viewport completely */
		html, body {
			margin: 0;
			padding: 0;
			overflow: hidden;
			height: 100%;
		}
	</style>

	<div id="editor-root" class="h-screen w-screen">
		<EditorLayout client:only="react" />
	</div>
</BaseLayout>
